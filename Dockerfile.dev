# Dockerfile de desarrollo para el backend de Spring Boot
FROM maven:3.9-eclipse-temurin-17

WORKDIR /app

# Copiar el archivo pom.xml
COPY backend/pom.xml .
RUN mvn dependency:go-offline -B

# Copiar el código fuente
COPY backend/src ./src

EXPOSE 8080
EXPOSE 5005

# Comando para ejecutar en modo desarrollo con hot reload
CMD ["mvn", "spring-boot:run", "-Dspring-boot.run.jvmArguments=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=n,address=*:5005"]
